  "command": "refresh_weather_measurements",
  "scraper": "earthengine",
  "filters": [
    {
      "iso2": [
        "IN"
      ],
      "region_type": "gadm1",
      "date_from": "2020-01-01",
      "date_to": "2024-06-26",
      "date_direction": -1,
      "variable": [
        "heat_index",
        "temperature"
      ]
    }
  ]
}